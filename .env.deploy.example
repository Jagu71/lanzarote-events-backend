DOMAIN=events.example.com
APP_NAME=Lanzarote Events Backend
ENVIRONMENT=production
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:////data/lanzarote_events.db
DEFAULT_LOCALE=es
SUPPORTED_LOCALES=es,en,de,fr
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_USER_AGENT=LanzaroteEventsBot/0.1 (+production)
SCRAPER_USE_FIXTURES=false
SCRAPE_INTERVAL_MINUTES=180
CACT_EVENTS_URL=https://cactlanzarote.com/tipo_entrada/eventos/
CULTURALANZAROTE_PROGRAM_URL=https://culturalanzarote.com/programacion_cultura/
CULTURALANZAROTE_TICKETS_URL=https://culturalanzarote.sacatuentrada.es/es
LAVOZ_LANZAROTE_URL=https://www.lavozdelanzarote.com/actualidad/cultura
CABILDO_EVENTS_URL=
